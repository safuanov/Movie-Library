import tkinter as tk
from tkinter import ttk, messagebox  # Импорт дополнительных виджетов и окна сообщений
import json  # Для работы с JSON-файлами
import os  # Для проверки существования файлов

class MovieLibrary:
    def __init__(self, root): # Инициализация приложения
        self.root = root
        self.root.title("Личная кинотека")  # Заголовок окна
        self.movies = []  # Список для хранения фильмов
        self.load_movies()  # Загрузка фильмов при запуске
        self.setup_ui()  # Настройка интерфейса

    def setup_ui(self): # Создание пользовательского интерфейса
        tk.Label(self.root, text="Название:").grid(row=0, column=0, sticky="w", padx=5, pady=2) # Поля ввода с подписями
        self.title_entry = tk.Entry(self.root, width=30)
        self.title_entry.grid(row=0, column=1, padx=5, pady=2)

        tk.Label(self.root, text="Жанр:").grid(row=1, column=0, sticky="w", padx=5, pady=2) # Поля ввода с подписями
        self.genre_entry = tk.Entry(self.root, width=30)
        self.genre_entry.grid(row=1, column=1, padx=5, pady=2)

        tk.Label(self.root, text="Год выпуска:").grid(row=2, column=0, sticky="w", padx=5, pady=2) # Поля ввода с подписями
        self.year_entry = tk.Entry(self.root, width=30)
        self.year_entry.grid(row=2, column=1, padx=5, pady=2)

        tk.Label(self.root, text="Рейтинг (0–10):").grid(row=3, column=0, sticky="w", padx=5, pady=2) # Поля ввода с подписями
        self.rating_entry = tk.Entry(self.root, width=30)
        self.rating_entry.grid(row=3, column=1, padx=5, pady=2)

        tk.Button(self.root, text="Добавить фильм", command=self.add_movie).grid(row=4, column=0, pady=10) # Кнопки управления
        tk.Button(self.root, text="Обновить", command=self.refresh_table).grid(row=4, column=1) # Кнопки управления

        self.tree = ttk.Treeview(self.root, columns=("Название", "Жанр", "Год", "Рейтинг"), show="headings") # Таблица для отображения фильмов
        self.tree.heading("Название", text="Название")
        self.tree.heading("Жанр", text="Жанр")
        self.tree.heading("Год", text="Год")
        self.tree.heading("Рейтинг", text="Рейтинг")
        self.tree.grid(row=5, column=0, columnspan=2, padx=5, pady=5)

        tk.Label(self.root, text="Фильтр по жанру:").grid(row=6, column=0, sticky="w") # Элементы фильтрации
        self.filter_genre = tk.StringVar(value="Все")
        ttk.Combobox(self.root, textvariable=self.filter_genre,
                   values=["Все", "Боевик", "Драма", "Комедия", "Фантастика", "Триллер"]).grid(row=6, column=1, padx=5, pady=5)

        tk.Label(self.root, text="Фильтр по году:").grid(row=7, column=0, sticky="w") # Элементы фильтрации
        self.filter_year = tk.Entry(self.root, width=30)
        self.filter_year.grid(row=7, column=1, padx=5, pady=5)
        tk.Button(self.root, text="Применить фильтр", command=self.apply_filter).grid(row=8, column=0, columnspan=2, pady=10)

    def validate_input(self, title, genre, year, rating): # Валидация введённых данных
        if not title or not genre: # Проверка на пустые поля названия и жанра
            messagebox.showerror("Ошибка", "Название и жанр не могут быть пустыми!")
            return False

        try: # Проверка корректности года
            year_int = int(year)
            if year_int < 1888 or year_int > 2026:  # 1888 — год первого фильма
                messagebox.showerror("Ошибка", "Год должен быть от 1888 до 2026!")
                return False
        except ValueError:
            messagebox.showerror("Ошибка", "Год должен быть числом!")
            return False

        try: # Проверка корректности рейтинга
            rating_float = float(rating)
            if rating_float < 0 or rating_float > 10:
                messagebox.showerror("Ошибка", "Рейтинг должен быть от 0 до 10!")
                return False
        except ValueError:
            messagebox.showerror("Ошибка", "Рейтинг должен быть числом!")
            return False

        return True

    def add_movie(self): # Добавление нового фильма
        title = self.title_entry.get().strip()
        genre = self.genre_entry.get().strip()
        year = self.year_entry.get().strip()
        rating = self.rating_entry.get().strip()

        if self.validate_input(title, genre, year, rating):
            movie = {
                "title": title,
                "genre": genre,
                "year": int(year),
                "rating": float(rating)
            }
            self.movies.append(movie)
            self.save_movies()  # Сохранение в JSON
            self.refresh_table()  # Обновление таблицы
            self.clear_entries()  # Очистка полей ввода

    def clear_entries(self): # Очистка полей ввода после добавления фильма
        self.title_entry.delete(0, tk.END)
        self.genre_entry.delete(0, tk.END)
        self.year_entry.delete(0, tk.END)
        self.rating_entry.delete(0, tk.END)

    def refresh_table(self): # Обновление таблицы с фильмами
        for item in self.tree.get_children():
            self.tree.delete(item)
        for movie in self.movies:
            self.tree.insert("", "end", values=(
                movie["title"], movie["genre"], movie["year"], f"{movie['rating']:.1f}"
            ))

    def apply_filter(self): # Применение фильтров к отображаемым фильмам
        filter_genre = self.filter_genre.get()
        filter_year_text = self.filter_year.get().strip()

        filtered_movies = self.movies

        if filter_genre != "Все": # Фильтрация по жанру
            filtered_movies = [m for m in filtered_movies if m["genre"] == filter_genre]

        if filter_year_text: # Фильтрация по году
            try:
                filter_year = int(filter_year_text)
                filtered_movies = [m for m in filtered_movies if m["year"] == filter_year]
            except ValueError:
                messagebox.showerror("Ошибка", "Год для фильтрации должен быть числом!")
                return

        for item in self.tree.get_children(): # Обновление таблицы с учётом фильтров
            self.tree.delete(item)
        for movie in filtered_movies:
            self.tree.insert("", "end", values=(
                movie["title"], movie["genre"], movie["year"], f"{movie['rating']:.1f}"
            ))

    def load_movies(self): # Загрузка фильмов из JSON-файла при запуске
        if os.path.exists("movies.json"):
            with open("movies.json", "r", encoding="utf-8") as f:
                self.movies = json.load(f)

    def save_movies(self): # Сохранение фильмов в JSON-файл
        with open("movies.json", "w", encoding="utf-8") as f:
            json.dump(self.movies, f, ensure_ascii=False, indent=4)

if __name__ == "__main__":
    root = tk.Tk()
    app = MovieLibrary(root)
    root.mainloop()
